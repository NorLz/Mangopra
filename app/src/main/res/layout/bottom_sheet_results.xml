<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bottomSheetRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bottom_sheet_bg"
    android:paddingTop="12dp"
    android:paddingBottom="16dp">

    <!-- Drag Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:layout_marginBottom="12dp"
        android:background="@drawable/drag_handle_bg" />

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/beige_bg"
                android:padding="6dp"
                android:src="@drawable/manage_search"
                app:tint="#1C1B1F"/>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Real-time Scan Results"
                android:textSize="14sp"
                android:fontFamily="@font/inter_extrabold"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/btnClose"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_alignParentEnd="true"
            android:src="@drawable/cross_small"
            app:tint="#1C1B1F"/>
    </RelativeLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"/>

    <!-- Quality Summary Section -->
    <LinearLayout
        android:id="@+id/layoutSummarySection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <!-- ================= GRADE I CARD ================= -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardGrade1"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E0E0E0">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <View
                    android:layout_width="6dp"
                    android:layout_height="match_parent"
                    android:background="#4CAF50"/>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="12dp">

                    <ImageView
                        android:id="@+id/imgGrade1Icon"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentTop="true"
                        android:padding="10dp"
                        android:src="@drawable/check_circle"
                        app:tint="#2E7D32"/>

                    <TextView
                        android:id="@+id/tvGrade1Count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:text="3"
                        android:textSize="40sp"
                        android:textStyle="bold"
                        android:textColor="#1C1B1F"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/tvGrade1Count"
                        android:layout_centerHorizontal="true"
                        android:text="Grade I copra"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#4CAF50"/>
                </RelativeLayout>
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>


        <!-- ================= GRADE II CARD ================= -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardGrade2"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E0E0E0">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <View
                    android:layout_width="6dp"
                    android:layout_height="match_parent"
                    android:background="#FB9F1F"/>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="12dp">

                    <ImageView
                        android:id="@+id/imgGrade2Icon"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentTop="true"
                        android:padding="10dp"
                        android:src="@drawable/warning__1_"
                        app:tint="#F9A825"/>

                    <TextView
                        android:id="@+id/tvGrade2Count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:text="3"
                        android:textSize="40sp"
                        android:textStyle="bold"
                        android:textColor="#1C1B1F"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/tvGrade2Count"
                        android:layout_centerHorizontal="true"
                        android:text="Grade II copra"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#F9A825"/>
                </RelativeLayout>
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>


        <!-- ================= GRADE III CARD ================= -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardGrade3"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_weight="1"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E0E0E0">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <View
                    android:layout_width="6dp"
                    android:layout_height="match_parent"
                    android:background="#FB5A48"/>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="12dp">

                    <ImageView
                        android:id="@+id/imgGrade3Icon"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentTop="true"
                        android:padding="10dp"
                        android:src="@drawable/block__1_"
                        app:tint="#C62828"/>

                    <TextView
                        android:id="@+id/tvGrade3Count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:text="2"
                        android:textSize="40sp"
                        android:textStyle="bold"
                        android:textColor="#1C1B1F"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/tvGrade3Count"
                        android:layout_centerHorizontal="true"
                        android:text="Grade III copra"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#C62828"/>
                </RelativeLayout>
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"/>

    <!-- Section Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Detected Copra Images"
        android:fontFamily="@font/inter_bold"
        android:textSize="14sp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"/>

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerImages"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false"/>

    <include layout="@layout/item_pagination_foooter"/>
</LinearLayout>