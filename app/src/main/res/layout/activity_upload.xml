<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#000">

    <!-- Top App Bar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topBar2"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FEFEFE"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upload Image Copra"
            android:textSize="14sp"
            android:fontFamily="@font/inter_semibold"
            android:textColor="#000000"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="68dp"/>

    </com.google.android.material.appbar.MaterialToolbar>

    <!-- Back Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:gravity="center"
        android:paddingStart="40dp"
        android:paddingEnd="32dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="4dp"
        android:backgroundTint="#FCE9CE"
        android:textColor="#1C1B1F"
        app:cornerRadius="10dp"
        app:icon="@drawable/arrow_small_left"
        app:iconGravity="textStart"
        app:iconTint="#1C1B1F"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@id/topBar2"
        app:layout_constraintTop_toTopOf="parent"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        app:layout_constraintBottom_toBottomOf="@+id/topBar2" />

    <!-- Main Scrollable Content -->
    <FrameLayout
        android:id="@+id/frameContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#FEFEFE"
        app:layout_constraintTop_toBottomOf="@id/topBar2"
        app:layout_constraintBottom_toTopOf="@id/bottomControls2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Upload image of the copra"
                    android:fontFamily="@font/inter_extrabold"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#000"
                    android:layout_gravity="center"
                    android:layout_marginTop="12dp"/>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/uploadBox"
                    android:layout_width="match_parent"
                    android:layout_marginTop="24dp"
                    android:layout_height="300dp"
                    android:backgroundTint="#00000000"
                    app:cardCornerRadius="16dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#000000">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <!-- 🔥 IMAGE PREVIEW -->
                        <ImageView
                            android:id="@+id/imgPreview"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:visibility="gone"/>

                        <com.example.copra.BoundingBoxView
                            android:id="@+id/boundingOverlay"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:visibility="gone"/>
                        <!-- 🔥 DEFAULT UPLOAD CONTENT -->
                        <LinearLayout
                            android:id="@+id/uploadContent"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="24dp">

                            <ImageView
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:src="@drawable/add_image"
                                app:tint="#1C1B1F"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Select existing copra image and upload here"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#000"
                                android:gravity="center"
                                android:layout_marginTop="16dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="JPEG and PNG formats, up to 50 mb."
                                android:textSize="12sp"
                                android:textColor="#666666"
                                android:layout_marginTop="4dp"/>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnSelectImage"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Select Image"
                                android:fontFamily="@font/inter_bold"
                                android:layout_marginTop="24dp"
                                android:backgroundTint="#FFEDD4"
                                android:textColor="#1C1B1F"
                                app:strokeColor="#1C1B1F"
                                app:strokeWidth="1dp"
                                app:cornerRadius="10dp"/>
                        </LinearLayout>

                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- FILE UPLOAD CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/uploadProgressCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#1C1B1F"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="#FFFFFF"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/picture"
                                android:layout_marginEnd="12dp"/>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/txtFileName"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="copra-image.jpeg"
                                    android:textStyle="bold"
                                    android:textSize="13sp"/>

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginTop="8dp">

                                    <TextView
                                        android:id="@+id/txtUploadStatus"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Uploading..."
                                        android:textSize="11sp"
                                        android:textColor="#666666"/>

                                    <ImageView
                                        android:id="@+id/imgCheck"
                                        android:layout_width="14dp"
                                        android:layout_height="14dp"
                                        android:layout_marginStart="6dp"
                                        android:src="@drawable/check_circle"
                                        app:tint="#4CAF50"
                                        android:visibility="gone"/>

                                </LinearLayout>


                            </LinearLayout>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnRemove"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_marginBottom="18dp"
                                android:layout_marginEnd="0dp"
                                android:background="#FEFEFE"
                                android:scaleType="centerInside"
                                android:padding="10dp"
                                app:icon="@drawable/cross_small"
                                app:iconSize="18dp"
                                app:iconTint="#1C1B1F"
                                app:backgroundTint="#FEFEFE"/>
                        </LinearLayout>

                        <!-- Progress Bar -->
                        <ProgressBar
                            android:id="@+id/uploadProgressBar"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:layout_marginTop="12dp"
                            android:progress="30"
                            android:max="100"
                            android:progressTint="#AE7049"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Analyze Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAnalyzeQuality"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Analyze Quality"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#1C1B1F"
                    android:layout_marginTop="16dp"
                    android:visibility="gone"
                    app:cornerRadius="12dp"/>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/loadingContainer"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <ProgressBar
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:indeterminate="true"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Analyzing quality..."
                            android:layout_marginStart="12dp"
                            android:textSize="14sp"
                            android:textColor="#666666"/>
                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </ScrollView>
    </FrameLayout>

    <!-- Bottom Controls -->
    <LinearLayout
        android:id="@+id/bottomControls2"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#FEFEFE"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGallery2"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:paddingStart="4dp"
            app:backgroundTint="#FEFEFE"
            app:cornerRadius="28dp"
            app:icon="@drawable/upload__1_"
            app:iconSize="34dp"
            app:iconTint="#1C1B1F"
            app:iconGravity="textStart"
            app:iconPadding="0dp" />

        <Space
            android:layout_width="62dp"
            android:layout_height="wrap_content"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScan2"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:paddingStart="2dp"
            android:backgroundTint="#FEFEFE"
            app:cornerRadius="28dp"
            app:icon="@drawable/scan"
            app:iconSize="34dp"
            app:iconTint="#1C1B1F"
            app:iconGravity="textStart"
            app:iconPadding="0dp" />

        <Space
            android:layout_width="62dp"
            android:layout_height="wrap_content"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirm2"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:backgroundTint="#FEFEFE"
            app:cornerRadius="28dp"
            app:icon="@drawable/check"
            app:iconSize="20dp"
            app:iconTint="#1C1B1F"
            app:iconGravity="textStart"
            app:iconPadding="0dp"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>